DIRECT_ICAL_TOKEN_CITY_VIEW_STUDIO=
DIRECT_ICAL_TOKEN_PENTHOUSE_SUITE=
DIRECT_ICAL_TOKEN_LOFT_RESIDENCY=
DIRECT_ICAL_TOKEN_MASTER_SUITE=
DIRECT_ICAL_TOKEN_EXECUTIVE_STUDIO=
PUBLIC_SITE_URL=https://woodstreetcollective.com
VITE_GA_MEASUREMENT_ID=

# Keep Airbnb iCal URLs server-side only. Do not prefix these with VITE_.
